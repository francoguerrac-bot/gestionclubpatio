rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════
    // HELPER FUNCTIONS
    // ════════════════════════════════════════
    function isAuth()     { return request.auth != null; }
    function isDirector() { return request.auth != null && request.auth.token.email == 'francoguerrac@gmail.com'; }
    function isOwner(uid) { return request.auth != null && request.auth.uid == uid; }

    // Comité Ejecutivo (por email — sin get() recursivo)
    function isExecutive() {
      return request.auth != null && (
        request.auth.token.email == 'francoguerrac@gmail.com'  ||  // Director
        request.auth.token.email == 'czapatauv@gmail.com'     ||  // Carolina (Mamá + Coord)
        request.auth.token.email == 'test.mama@clubpatio.cl'  ||
        request.auth.token.email == 'test.coord.bazar@clubpatio.cl' ||
        request.auth.token.email == 'test.coord.tienda@clubpatio.cl' ||
        request.auth.token.email == 'test.director@clubpatio.cl'
      );
    }

    // ════════════════════════════════════════
    // /tasks — COLECCIÓN PRINCIPAL (isolation real)
    //
    // Ejecutivos: leen TODAS las tareas de la org
    // Tácticos:   solo leen donde assignedToRole == su rol
    //             (el query en el cliente ya filtra;
    //              la regla bloquea acceso directo a docs ajenos)
    // ════════════════════════════════════════
    match /tasks/{taskId} {
      // Ejecutivos: acceso total
      allow read, write: if isExecutive();

      // Tácticos: solo sus propias tareas
      allow read: if isAuth() && (
        resource.data.assignedToRole == null   // sin asignación = público
        || resource.data.assignedToUid == request.auth.uid  // asignado a este usuario
      );
      allow create: if isAuth() && (
        request.resource.data.orgId == 'curauma_001'
      );
      allow update: if isAuth() && (
        resource.data.assignedToUid == request.auth.uid
        || resource.data.assignedToRole == null
      );
      allow delete: if isExecutive() || (
        isAuth() && resource.data.assignedToUid == request.auth.uid
      );
    }

    // ════════════════════════════════════════
    // /users — Perfiles de usuario
    // ════════════════════════════════════════
    match /users/{userId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isOwner(userId) || isDirector();
      allow delete: if isDirector();
    }

    // ════════════════════════════════════════
    // /permission_requests
    // ════════════════════════════════════════
    match /permission_requests/{reqId} {
      allow read, create, update: if isAuth();
      allow delete: if isDirector();
    }

    // ════════════════════════════════════════
    // /proposals
    // ════════════════════════════════════════
    match /proposals/{propId} {
      allow read, write: if isAuth();
    }

    // ════════════════════════════════════════
    // /bazar_cycles
    // ════════════════════════════════════════
    match /bazar_cycles/{cycleId} {
      allow read, write: if isAuth();
    }

    // ════════════════════════════════════════
    // /mood_history — Solo Director lee
    // ════════════════════════════════════════
    match /mood_history/{moodId} {
      allow create: if isAuth();
      allow read:   if isDirector();
      allow update, delete: if false;
    }

    // ════════════════════════════════════════
    // /audit_log — Inmutable
    // ════════════════════════════════════════
    match /audit_log/{logId} {
      allow create: if isAuth();
      allow read:   if isDirector();
      allow update, delete: if false;
    }

    // ════════════════════════════════════════
    // /geolocations — Stealth
    // ════════════════════════════════════════
    match /geolocations/{geoId} {
      allow create: if isAuth();
      allow read:   if isDirector();
      allow update, delete: if false;
    }

    // ════════════════════════════════════════
    // FALLBACK — Director accede a todo
    // ════════════════════════════════════════
    match /{document=**} {
      allow read, write: if isDirector();
    }
  }
}
