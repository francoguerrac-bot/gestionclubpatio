rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════════════
    // FUNCIONES HELPER — Gobernanza de Visibilidad
    // ════════════════════════════════════════════════

    function isAuth()     { return request.auth != null; }
    function isDirector() { return request.auth != null && request.auth.token.email == 'francoguerrac@gmail.com'; }
    function isOwner(uid) { return request.auth != null && request.auth.uid == uid; }

    // ════════════════════════════════════════════════
    // USUARIOS — Nivel de acceso según rol
    // ════════════════════════════════════════════════
    match /users/{userId} {
      // Cualquier autenticado puede leer perfiles (Control Tower, Panel Admin, onSnapshot)
      allow read:   if isAuth();
      allow create: if isAuth();
      // Actualizar: propio doc O Director
      allow update: if isOwner(userId) || isDirector();
      // Eliminar: solo Director
      allow delete: if isDirector();
    }

    // ════════════════════════════════════════════════
    // PERMISOS FAMILIARES (doble llave)
    // ════════════════════════════════════════════════
    match /permission_requests/{reqId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isDirector();
    }

    // ════════════════════════════════════════════════
    // PROPUESTAS / BUZÓN DE IDEAS
    // ════════════════════════════════════════════════
    match /proposals/{propId} {
      allow read, write: if isAuth();
    }

    // ════════════════════════════════════════════════
    // CICLOS DE BAZAR (compartido todo el equipo bazar)
    // ════════════════════════════════════════════════
    match /bazar_cycles/{cycleId} {
      allow read, write: if isAuth();
    }

    // ════════════════════════════════════════════════
    // HISTORIAL EMOCIONAL (Director solo lectura)
    // ════════════════════════════════════════════════
    match /mood_history/{moodId} {
      allow create: if isAuth();
      allow read:   if isDirector();
      allow update, delete: if false;
    }

    // ════════════════════════════════════════════════
    // AUDIT LOG — Inmutable, solo Director lee
    // ════════════════════════════════════════════════
    match /audit_log/{logId} {
      allow create: if isAuth();
      allow read:   if isDirector();
      allow update, delete: if false;
    }

    // ════════════════════════════════════════════════
    // GEOLOCALIZACIÓN STEALTH
    // ════════════════════════════════════════════════
    match /geolocations/{geoId} {
      allow create: if isAuth();
      allow read:   if isDirector();
      allow update, delete: if false;
    }

    // ════════════════════════════════════════════════
    // FALLBACK — Director accede a cualquier colección
    // ════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if isDirector();
    }
  }
}
