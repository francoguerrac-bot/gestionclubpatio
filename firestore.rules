rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth()     { return request.auth != null; }
    function isOwner(uid) { return request.auth != null && request.auth.uid == uid; }

    function isDirector() {
      return request.auth != null
          && request.auth.token.email == 'francoguerrac@gmail.com';
    }

    function isExecutive() {
      return request.auth != null && (
        request.auth.token.email == 'francoguerrac@gmail.com'       ||
        request.auth.token.email == 'czapatauv@gmail.com'           ||
        request.auth.token.email == 'test.director@clubpatio.cl'    ||
        request.auth.token.email == 'test.mama@clubpatio.cl'        ||
        request.auth.token.email == 'test.coord.bazar@clubpatio.cl' ||
        request.auth.token.email == 'test.coord.tienda@clubpatio.cl'
      );
    }

    // ── /users/{userId}/tokens — Subcolección de tokens FCM ──
    match /users/{userId}/tokens/{tokenId} {
      allow read, write: if isOwner(userId);
    }

    // ── /tasks ──
    match /tasks/{taskId} {
      allow read, write: if isExecutive();
      allow read: if isAuth() && (
        resource.data.assignedToUid == request.auth.uid
        || resource.data.assignedToUid == null
        || resource.data.assignedToUid == ''
      );
      allow create: if isAuth()
        && request.resource.data.orgId == 'curauma_001'
        && request.resource.data.assignedToUid == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.assignedToUid == request.auth.uid
        || resource.data.assignedToUid == null
        || resource.data.assignedToUid == ''
      );
      allow delete: if isExecutive()
        || (isAuth() && resource.data.assignedToUid == request.auth.uid);
    }

    // ── /users ──
    match /users/{userId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isOwner(userId) || isDirector();
      allow delete: if isDirector();
    }

    // ── /permission_requests ──
    match /permission_requests/{reqId} {
      allow read, create, update: if isAuth();
      allow delete: if isDirector();
    }

    match /proposals/{propId}     { allow read, write: if isAuth(); }
    match /bazar_cycles/{cycleId} { allow read, write: if isAuth(); }

    // ── /mood_history ──
    match /mood_history/{moodId} {
      allow create: if isAuth();
      allow read:   if isDirector();
      allow update, delete: if false;
    }

    // ── /audit_log ──
    match /audit_log/{logId} {
      allow create: if isAuth();
      allow read:   if isDirector();
      allow update, delete: if false;
    }

    // ── /activity_logs ──
    match /activity_logs/{logId} {
      allow create: if isAuth();
      allow read:   if isExecutive();
      allow update, delete: if false;
    }

    // ── /geolocations ──
    match /geolocations/{geoId} {
      allow create: if isAuth();
      allow read:   if isDirector();
      allow update, delete: if false;
    }

    // ── /notification_logs — Log de entrega por usuario ──
    // SW escribe sin auth; cada usuario lee solo sus propios logs
    match /notification_logs/{logId} {
      allow create: if true;
      allow read:   if isAuth() && (
        resource.data.userId == request.auth.uid || isDirector()
      );
      allow update, delete: if false;
    }

    // ── /fcm_sw_logs — Log técnico completo ──
    // SW escribe sin auth; solo Director puede leer
    match /fcm_sw_logs/{logId} {
      allow create: if true;
      allow read:   if isDirector();
      allow update, delete: if false;
    }

    // ── FALLBACK — Director accede a todo lo demás ──
    match /{document=**} {
      allow read, write: if isDirector();
    }
  }
}
