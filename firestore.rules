rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Función helper: verificar si el solicitante es el Director ──
    function isDirector() {
      return request.auth != null &&
             request.auth.token.email == 'francoguerrac@gmail.com';
    }

    // ── Función helper: usuario autenticado ──
    function isAuth() {
      return request.auth != null;
    }

    // ── COLECCIÓN USERS ──
    match /users/{userId} {
      // Cualquier usuario autenticado puede leer (para Control Tower y Panel Admin)
      allow read: if isAuth();

      // Cada usuario escribe su propio doc, O el Director escribe cualquiera
      allow create: if isAuth();
      allow update: if isAuth() && (
        request.auth.uid == userId || isDirector()
      );
      allow delete: if isDirector();
    }

    // ── SOLICITUDES DE PERMISOS (módulo Casa - doble llave) ──
    match /permission_requests/{reqId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isDirector();
    }

    // ── PROPUESTAS / BUZÓN DE IDEAS ──
    match /proposals/{propId} {
      allow read, write: if isAuth();
    }

    // ── CICLOS DE BAZAR ──
    match /bazar_cycles/{cycleId} {
      allow read, write: if isAuth();
    }

    // ── AUDIT LOG (solo Director puede leer) ──
    match /audit_log/{logId} {
      allow create: if isAuth();
      allow read:   if isDirector();
    }

    // ── GEOLOCALIZACIÓN STEALTH (solo Director puede leer) ──
    match /geolocations/{geoId} {
      allow create: if isAuth();
      allow read:   if isDirector();
    }
  }
}
