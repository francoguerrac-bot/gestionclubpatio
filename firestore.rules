rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════════════
    // FUNCIONES HELPER
    // ════════════════════════════════════════════════

    // Usuario autenticado (cualquier login válido)
    function isAuth() {
      return request.auth != null;
    }

    // Director identificado por email (sin get() — siempre disponible)
    function isDirector() {
      return request.auth != null
          && request.auth.token.email == 'francoguerrac@gmail.com';
    }

    // El usuario está accediendo a su propio documento
    function isOwner(userId) {
      return request.auth != null
          && request.auth.uid == userId;
    }

    // ════════════════════════════════════════════════
    // COLECCIÓN: users
    // ════════════════════════════════════════════════
    match /users/{userId} {
      // Cualquier usuario logueado puede LEER cualquier perfil
      // (necesario para Control Tower, Panel Admin, onSnapshot del Director)
      allow read: if isAuth();

      // Crear: cualquier usuario puede crear su propio perfil
      allow create: if isAuth();

      // Actualizar: propio documento O Director
      allow update: if isOwner(userId) || isDirector();

      // Eliminar: solo Director
      allow delete: if isDirector();
    }

    // ════════════════════════════════════════════════
    // COLECCIÓN: bazar_cycles
    // Ciclos semanales compartidos entre todos los roles de Bazar
    // ════════════════════════════════════════════════
    match /bazar_cycles/{cycleId} {
      allow read, write: if isAuth();
    }

    // ════════════════════════════════════════════════
    // COLECCIÓN: permission_requests
    // Solicitudes de permiso (hijos → padres, doble llave)
    // ════════════════════════════════════════════════
    match /permission_requests/{reqId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();  // Mamá y Director pueden aprobar/rechazar
      allow delete: if isDirector();
    }

    // ════════════════════════════════════════════════
    // COLECCIÓN: proposals
    // Buzón de ideas de los integrantes
    // ════════════════════════════════════════════════
    match /proposals/{propId} {
      allow read, write: if isAuth();
    }

    // ════════════════════════════════════════════════
    // COLECCIÓN: audit_log
    // Solo Director puede leer; cualquiera puede escribir (stealth)
    // ════════════════════════════════════════════════
    match /audit_log/{logId} {
      allow create: if isAuth();
      allow read:   if isDirector();
      allow update, delete: if false;  // inmutable
    }

    // ════════════════════════════════════════════════
    // COLECCIÓN: geolocations
    // Geofencing stealth — solo Director puede leer
    // ════════════════════════════════════════════════
    match /geolocations/{geoId} {
      allow create: if isAuth();
      allow read:   if isDirector();
      allow update, delete: if false;  // inmutable
    }

    // ════════════════════════════════════════════════
    // CUALQUIER OTRA COLECCIÓN (fallback seguro)
    // ════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if isDirector();
    }
  }
}
